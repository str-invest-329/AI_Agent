# 複製此檔為 .env 並填入你的 API Key
# cp .env.example .env

# FRED API Key（必要）
# 申請：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BLS API Key（選用，不填用匿名模式，限每日 25 次）
# 申請：https://www.bls.gov/developers/home.htm
BLS_API_KEY=

# BEA API Key（選用）
# 申請：https://apps.bea.gov/API/docs/index.htm
BEA_API_KEY=

# Finnhub API Key（股市指數即時價格）
# 申請：https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
